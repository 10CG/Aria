{
  "$schema": "./hooks-schema.json",
  "version": "1.0.0",
  "enabled": true,
  "hooks": {
    "session-start": {
      "enabled": true,
      "script": "session-start.sh",
      "description": "会话开始时执行环境检查和配置加载",
      "timeout": 30,
      "run_on": ["SessionStart"],
      "blocking": false
    },
    "pre-commit": {
      "enabled": false,
      "script": "pre-commit.sh",
      "description": "提交前运行测试和检查",
      "timeout": 300,
      "run_on": ["PreCommit"],
      "blocking": true
    },
    "task-complete": {
      "enabled": false,
      "script": "task-complete.sh",
      "description": "任务完成时执行验证和清理",
      "timeout": 60,
      "run_on": ["TaskComplete"],
      "blocking": false
    }
  },
  "validators": {
    "spec-compliance": {
      "enabled": true,
      "module": "validators/spec-compliance.py",
      "checks": [
        "openspec_format",
        "upm_sync",
        "arch_doc_sync"
      ]
    },
    "code-quality": {
      "enabled": true,
      "module": "validators/code-quality.py",
      "checks": [
        "test_coverage",
        "code_complexity",
        "security_scan"
      ],
      "thresholds": {
        "test_coverage": 85,
        "code_complexity": 10
      }
    }
  },
  "fallback": {
    "on_error": "log",
    "on_timeout": "warn",
    "continue_on_failure": true
  }
}
