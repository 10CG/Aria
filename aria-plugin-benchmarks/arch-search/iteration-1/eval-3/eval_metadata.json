{
  "eval_id": 3,
  "eval_name": "layer1-api-contract-routing",
  "category": "layer-1-routing",
  "prompt": "API 端点定义在哪",
  "expected_layer": 1,
  "expected_domain": "network",
  "expected_document_path": "shared/contracts/openapi/",
  "assertions": [
    {
      "id": "A1",
