{
  "eval_id": 3,
  "eval_name": "ambiguous-task-routing",
  "category": "confidence",
  "prompt": "Route this task: 'Update the user profile feature to sync data between the mobile app and backend API.'",
  "setup": {
    "task_type": "cross_domain",
    "file_paths": ["mobile/lib/features/profile/", "backend/src/routes/profile.py"],
    "keywords": ["sync", "mobile", "backend", "API"]
  },
  "assertions": [
    {
      "id": "A1",
      "name": "low_confidence_detected",
      "description": "Ambiguous task should produce confidence <= 0.70",
      "check": "confidence <= 0.70",
      "severity": "critical"
    },
    {
      "id": "A2",
      "name": "flags_ambiguity",
      "description": "Should flag that task spans multiple domains",
      "check": "output.match(/ambiguous|multiple|cross|span|unclear/i)",
      "severity": "high"
    },
    {
      "id": "A3",
      "name": "suggests_decomposition",
      "description": "Should suggest breaking task into sub-tasks or escalating",
      "check": "output.match(/decompose|split|break|sub-task|tech-lead/i)",
      "severity": "high"
    }
  ]
}
