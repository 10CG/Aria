{
  "_comment": "Aria 项目级配置 — 所有字段可选，未设置使用默认值。复制为 config.json 后修改。",
  "version": "1.0",

  "workflow": {
    "auto_proceed": false
  },

  "state_scanner": {
    "confidence_threshold": 90,
    "auto_execute_enabled": false,
    "auto_execute_rules": ["commit_only", "quick_fix", "doc_only"],
    "audit_log_path": ".aria/audit.log",

    "sync_check": {
      "_comment": "Phase 1.12 — 本地/远程同步检测 (v2.9.0)",
      "enabled": true,
      "check_submodules": true,
      "check_remote": false,
      "warn_after_hours": 24
    },

    "issue_scan": {
      "_comment": "Phase 1.13 — Issue 感知扫描 (v2.9.0, opt-in, 需网络+token)",
      "enabled": false,
      "platform": null,
      "platform_hostnames": {
        "forgejo": ["forgejo.10cg.pub"],
        "github": ["github.com"]
      },
      "cache_ttl_seconds": 900,
      "cache_path": ".aria/cache/issues.json",
      "stage_timeout_seconds": 12,
      "api_timeout_seconds": 5,
      "limit": 20,
      "label_filter": []
    }
  },

  "tdd": {
    "strictness": "advisory"
  },

  "benchmarks": {
    "require_before_merge": true,
    "skill_change_block_mode": "warn"
  },

  "experiments": {
    "agent_team_audit": false,
    "agent_team_audit_points": ["pre_merge"]
  }
}
