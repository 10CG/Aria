{
  "_comment": "Aria 项目级配置 — 首次启用 issue_scan 用于 Phase 1.13 dogfooding (2026-04-09)",
  "version": "1.0",

  "workflow": {
    "auto_proceed": false
  },

  "state_scanner": {
    "confidence_threshold": 90,
    "auto_execute_enabled": false,
    "auto_execute_rules": ["commit_only", "quick_fix", "doc_only"],
    "audit_log_path": ".aria/audit.log",

    "sync_check": {
      "enabled": true,
      "check_submodules": true,
      "check_remote": false,
      "warn_after_hours": 24
    },

    "issue_scan": {
      "_comment_submodules": "2026-04-15 启用 scan_submodules + stage_timeout 12→20 作为 state-scanner-submodule-issue-scan Spec 的 dogfooding — 防止 Aria meta-repo 模式下 aria-plugin / aria-orchestrator / aria-standards 的 issue 被漏扫",
      "enabled": true,
      "platform": "forgejo",
      "platform_hostnames": {
        "forgejo": ["forgejo.10cg.pub"],
        "github": ["github.com"]
      },
      "cache_ttl_seconds": 900,
      "cache_path": ".aria/cache/issues.json",
      "stage_timeout_seconds": 20,
      "api_timeout_seconds": 5,
      "limit": 20,
      "label_filter": [],
      "scan_submodules": true
    }
  },

  "tdd": {
    "strictness": "advisory"
  },

  "benchmarks": {
    "require_before_merge": true,
    "skill_change_block_mode": "warn"
  },

  "experiments": {
    "agent_team_audit": false,
    "agent_team_audit_points": ["pre_merge"]
  },

  "orchestrator": {
    "dispatch_policy": {
      "tier1_action": "dispatch_ready",
      "tier2_action": "approval_required",
      "tier3_action": "human_only",
      "dry_run": false
    }
  }
}
